<%
  var panelTitle = 'Admin — Users';
  var panelRole = 'Admin';
  var pageTitle = 'User Management';
  var sidebarLinks = [
    { href: '/admin', icon: 'fa-tachometer-alt', label: 'Dashboard', key: 'dashboard' },
    { href: '/admin/analytics', icon: 'fa-chart-line', label: 'Analytics', key: 'analytics' },
    { href: '/admin/products', icon: 'fa-box', label: 'Products', key: 'products' },
    { href: '/admin/orders', icon: 'fa-shopping-bag', label: 'Orders', key: 'orders' },
    { href: '/admin/users', icon: 'fa-users', label: 'Users', key: 'users' }
  ];
%>
<%- include('../partials/panel-header', { panelTitle, panelRole, pageTitle, sidebarLinks, page }) %>

<div class="panel-card">
  <div class="panel-card-header">
    <h2><i class="fas fa-users"></i> All Users (<%= users.length %>)</h2>
  </div>
  <% if (users.length === 0) { %>
    <div class="panel-empty"><i class="fas fa-users"></i><p>No users found</p></div>
  <% } else { %>
    <div class="panel-table-wrap">
      <table class="panel-table">
        <thead><tr><th>Email</th><th>Name</th><th>Mobile</th><th>Role</th><th>Joined</th><th>Change Role</th></tr></thead>
        <tbody>
          <% users.forEach(function(u) { %>
            <tr>
              <td><strong><%= u.email %></strong></td>
              <td><%= u.name || '—' %></td>
              <td><%= u.mobile || '—' %></td>
              <td><span class="badge badge-<%= u.role %>"><%= u.role %></span></td>
              <td><small><%= new Date(u.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short',year:'numeric'}) %></small></td>
              <td>
                <select class="status-select" onchange="updateRole('/admin/users/<%= u._id %>/role', this.value)">
                  <% ['user','admin'].forEach(function(r) { %>
                    <option value="<%= r %>" <%= u.role === r ? 'selected' : '' %>><%= r.charAt(0).toUpperCase() + r.slice(1) %></option>
                  <% }); %>
                </select>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/panel-footer') %>
