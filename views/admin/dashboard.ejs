<%
  var panelTitle = 'Admin Dashboard';
  var panelRole = 'Admin';
  var pageTitle = 'Dashboard';
  var sidebarLinks = [
    { href: '/admin', icon: 'fa-tachometer-alt', label: 'Dashboard', key: 'dashboard' },
    { href: '/admin/analytics', icon: 'fa-chart-line', label: 'Analytics', key: 'analytics' },
    { href: '/admin/products', icon: 'fa-box', label: 'Products', key: 'products' },
    { href: '/admin/orders', icon: 'fa-shopping-bag', label: 'Orders', key: 'orders' },
    { href: '/admin/users', icon: 'fa-users', label: 'Users', key: 'users' }
  ];
%>
<%- include('../partials/panel-header', { panelTitle, panelRole, pageTitle, sidebarLinks, page }) %>

<!-- Stats -->
<div class="stats-grid">
  <div class="stat-card">
    <div class="stat-icon" style="background:#e8f5e0;color:#2d5016;"><i class="fas fa-rupee-sign"></i></div>
    <div><span class="value">₹<%= stats.revenue %></span><span class="label">Revenue</span></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:#fff3cd;color:#856404;"><i class="fas fa-shopping-bag"></i></div>
    <div><span class="value"><%= stats.totalOrders %></span><span class="label">Total Orders</span></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:#cce5ff;color:#004085;"><i class="fas fa-clock"></i></div>
    <div><span class="value"><%= stats.newOrders %></span><span class="label">New Orders</span></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:#d4edda;color:#155724;"><i class="fas fa-check"></i></div>
    <div><span class="value"><%= stats.delivered %></span><span class="label">Delivered</span></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:#fce4ec;color:#c62828;"><i class="fas fa-times"></i></div>
    <div><span class="value"><%= stats.cancelled %></span><span class="label">Cancelled</span></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:#e8d5f5;color:#6b21a8;"><i class="fas fa-cube"></i></div>
    <div><span class="value"><%= stats.totalProducts %></span><span class="label">Products</span></div>
  </div>
  <div class="stat-card">
    <div class="stat-icon" style="background:#d1ecf1;color:#0c5460;"><i class="fas fa-users"></i></div>
    <div><span class="value"><%= stats.totalUsers %></span><span class="label">Users</span></div>
  </div>
</div>

<!-- Recent Orders -->
<div class="panel-card">
  <div class="panel-card-header">
    <h2><i class="fas fa-clock"></i> Recent Orders</h2>
    <a href="/admin/orders" class="btn btn-sm btn-outline">View All</a>
  </div>
  <% if (orders.length === 0) { %>
    <div class="panel-empty"><i class="fas fa-inbox"></i><p>No orders yet</p></div>
  <% } else { %>
    <div class="panel-table-wrap">
      <table class="panel-table">
        <thead><tr><th>Order ID</th><th>Customer</th><th>Amount</th><th>Payment</th><th>Status</th><th>Date</th><th>Action</th></tr></thead>
        <tbody>
          <% orders.forEach(function(o) { %>
            <tr>
              <td><strong>#<%= o._id.toString().slice(-8).toUpperCase() %></strong></td>
              <td><%= o.shippingAddress.name %><br><small style="color:#999"><%= o.shippingAddress.mobile %></small></td>
              <td><strong>₹<%= o.totalAmount %></strong></td>
              <td><span class="badge badge-<%= o.paymentStatus %>"><%= o.paymentStatus %></span></td>
              <td><span class="badge badge-<%= o.orderStatus %>"><%= o.orderStatus.replace(/_/g,' ') %></span></td>
              <td><small><%= new Date(o.createdAt).toLocaleDateString('en-IN',{day:'numeric',month:'short'}) %></small></td>
              <td><a href="/admin/orders/<%= o._id %>" class="btn btn-xs btn-outline">View</a></td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>

<%- include('../partials/panel-footer') %>
